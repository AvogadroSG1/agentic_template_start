[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{.PythonPackage}}"
version = "0.1.0"
description = "Walking-skeleton Typer CLI"
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
  "typer>=0.12,<1.0",
]

[project.optional-dependencies]
dev = [
  "pytest>=8.2,<9.0",
  "pytest-cov>=5.0,<6.0",
  "pytest-mock>=3.14,<4.0",
]

[project.scripts]
app = "app.main:main"
