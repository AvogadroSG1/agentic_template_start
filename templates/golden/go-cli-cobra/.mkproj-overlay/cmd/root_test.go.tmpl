package cmd

import (
	"testing"

	"github.com/google/go-cmp/cmp"
)

func TestRootCommandRegistersServeAndConfigCommands(t *testing.T) {
	command := RootCommand()
	want := map[string]bool{
		"config": true,
		"serve":  true,
	}
	got := map[string]bool{}

	for name := range want {
		_, _, err := command.Find([]string{name})
		got[name] = err == nil
	}

	if diff := cmp.Diff(want, got); diff != "" {
		t.Fatalf("registered commands (-want +got):\n%s", diff)
	}
}
